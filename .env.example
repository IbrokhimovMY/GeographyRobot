# Required
BOT_TOKEN=your_bot_token_here

# Mini App URL — set to your domain after deploying
# Railway:  https://your-app.up.railway.app/app/index.html
# VPS:      https://yourdomain.com/app/index.html
WEBAPP_URL=

# Optional
API_PORT=8080

# Railway: set to /data/geography_bot.db  (mounted volume)
# VPS:     leave empty (defaults to geography_bot.db in project dir)
DB_PATH=
